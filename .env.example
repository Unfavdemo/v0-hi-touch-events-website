# Copy to `.env.local` for local development (Next.js loads `.env.local` automatically).
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Canonical public URL (metadata, absolute links, future OG/sitemap).
# Example: https://hitouchinc.com
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Contact page uses mailto: links (see lib/site.js contact.email).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# CMS / assets (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CMS_API_URL=
# CMS_API_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (optional — @vercel/analytics works on Vercel without env vars)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
