# Copy to `.env.local` for local development (Next.js loads `.env.local` automatically).
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Canonical public URL (metadata, absolute links, future OG/sitemap).
# Example: https://hitouchinc.com
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Inquiry / contact (wire up when you add a backend or third-party form handler)
# -----------------------------------------------------------------------------
# Server-only: secret for your API route or webhook verification.
# INQUIRY_WEBHOOK_SECRET=

# Public endpoint your client posts to (only if you expose a URL to the browser).
# NEXT_PUBLIC_INQUIRY_FORM_ENDPOINT=

# Email (e.g. Resend, SendGrid): use only on the server in Route Handlers.
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=

# -----------------------------------------------------------------------------
# CMS / assets (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CMS_API_URL=
# CMS_API_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (optional — @vercel/analytics works on Vercel without env vars)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
